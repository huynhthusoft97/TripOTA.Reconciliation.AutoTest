# Bộ test TỰ NẠP .env.<TEST_ENV> (vd .env.sit) qua dotenv — xem lib/env.ts.
# Copy file này thành .env.sit và điền giá trị. .env.* đã .gitignore (KHÔNG commit secrets).

TEST_ENV=sit

# Reconciliation System (SIT)
# Host APP — Playwright UI test
WEB_URL=https://reconciliation-app-sit.tripota.com.vn
# Host API BE — Vitest API test + gen SDK (đọc /swagger/v1/swagger.json từ đây).
# Đổi sang dev/local để gen SDK môi trường khác (vd https://reconciliation-api-dev.tripota.com.vn
# hoặc http://localhost:8080), hoặc set TEST_ENV / SDK_SPEC.
API_BASE_URL=https://reconciliation-api-sit.tripota.com.vn

# Tài khoản đăng nhập UI (điền trong .env.sit, không commit)
TEST_USER=
TEST_PASSWORD=
AUTH_TOKEN=

TIMEOUT_API=5000
TIMEOUT_BROWSER=30000
